{
  "name": "cti-backend",
  "version": "1.0.0",
  "description": "CTI Management System — Node.js backend with Hyperledger Fabric Gateway",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --runInBand --forceExit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@hyperledger/fabric-gateway": "^1.5.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "express-session": "^1.18.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "clearMocks": true
  }
}
